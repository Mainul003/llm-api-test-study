                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Error field present', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
